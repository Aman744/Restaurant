rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helper: safe lookup of user doc for role/tenantId ─────────────────
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAuthenticated() {
      return request.auth != null;
    }
    // Check custom claims first (set via Admin SDK), fall back to Firestore user doc
    function userRole() {
      return request.auth.token.get('role', getUserData().get('role', null));
    }
    function userTenantId() {
      return request.auth.token.get('tenantId', getUserData().get('tenantId', null));
    }
    function isSuperAdmin() {
      return isAuthenticated() && userRole() == 'super-admin';
    }
    function ownsTenant(tenantId) {
      return isAuthenticated() && (
        isSuperAdmin() ||
        userTenantId() == tenantId
      );
    }
    // ─── /users/{uid} ────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid == uid || isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }
    // ─── /tenants/{tenantId} ─────────────────────────────────────────────────
    // Super Admin manages tenant root documents.
    // Restaurant staff can read their own tenant doc.
    match /tenants/{tenantId} {
      allow read: if true;
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      // ─── Publicly readable menu items ──────────────────────────────────
      match /menu_items/{itemId} {
        allow read: if true;
        allow write: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }

      // ─── Publicly readable tables ──────────────────────────────────────
      match /tables/{tableId} {
        allow read, update: if true;
        allow write: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }

      // ─── Publicly readable rooms ────────────────────────────────────────
      match /rooms/{roomId} {
        allow read, update: if true;
        allow write: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }

      // ─── Publicly readable/writeable active room stays (for customer check-ins)
      match /active_room_stays/{stayId} {
        allow read, write: if true;
      }

      // ─── Publicly readable/writeable stay guests (for joining/session tokens)
      match /stay_guests/{guestId} {
        allow read, write: if true;
      }

      // ─── Publicly readable/createable housekeeping tasks (customers request services)
      match /housekeeping_tasks/{taskId} {
        allow read, create: if true;
        allow update, delete: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }

      // ─── Publicly createable room feedback
      match /room_feedback/{feedbackId} {
        allow create: if true;
        allow read: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }

      // ─── Publicly createable waiter alerts (Customers request assistance, staff read/write)
      match /waiter_alerts/{alertId} {
        allow create: if true;
        allow read, update, delete: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }

      // ─── Publicly createable orders (Customers submit orders, staff read/write)
      match /orders/{orderId} {
        allow create, get: if true;
        allow list, update, delete: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );

        match /order_items/{itemId} {
          allow create: if true;
          allow read, update, delete: if isAuthenticated() && (
            isSuperAdmin() ||
            userTenantId() == tenantId ||
            (
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
            )
          );
        }
      }

      // ─── Publicly readable/writeable table sessions (for shared carts/split bills)
      match /table_sessions/{sessionId} {
        allow read, write: if true;
      }

      // ─── Other subcollections (Users, Settings, Inventory, Reservations, etc.)
      match /{document=**} {
        allow read, write: if isAuthenticated() && (
          isSuperAdmin() ||
          userTenantId() == tenantId ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
          )
        );
      }
    }
    // ─── /subscriptions ──────────────────────────────────────────────────────
    match /subscriptions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    // ─── /system_settings ────────────────────────────────────────────────────
    match /system_settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    // ─── /auth_deletion_queue/{uid} ──────────────────────────────────────────
    match /auth_deletion_queue/{uid} {
      allow read, write: if isAuthenticated();
    }
  }
}
