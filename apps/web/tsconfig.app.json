{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "firebase/app": ["../../node_modules/@firebase/app"],
      "firebase/auth": ["../../node_modules/@firebase/auth"],
      "firebase/firestore": ["../../node_modules/@firebase/firestore"],
      "firebase/storage": ["../../node_modules/@firebase/storage"],
      "firebase/functions": ["../../node_modules/@firebase/functions"],
      "@restaurant-qr/core": ["../../packages/core/src"],
      "@restaurant-qr/infra": ["../../packages/infra/src"],
      "@restaurant-qr/ui": ["../../packages/ui/src"]
    },
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
